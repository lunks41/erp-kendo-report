    "DbConnection": "Data Source=YOUR_SERVER;Initial Catalog=YOUR_DATABASE;User Id=YOUR_USER;Password=YOUR_PASSWORD;Connect Timeout=60;TrustServerCertificate=True;MultipleActiveResultSets=true;",
    "DBConnection_Live": "Data Source=YOUR_SERVER;Initial Catalog=YOUR_DATABASE;User Id=YOUR_USER;Password=YOUR_PASSWORD;Connect Timeout=60;TrustServerCertificate=True;MultipleActiveResultSets=true;",
    "DBConnection_GEI": "Data Source=YOUR_SERVER;Initial Catalog=YOUR_DATABASE;User Id=YOUR_USER;Password=YOUR_PASSWORD;Connect Timeout=60;TrustServerCertificate=True;MultipleActiveResultSets=true;",
    "DBConnection_GEINEW": "Data Source=YOUR_SERVER;Initial Catalog=YOUR_DATABASE;User Id=YOUR_USER;Password=YOUR_PASSWORD;Connect Timeout=60;TrustServerCertificate=True;MultipleActiveResultSets=true;",
    "Reporting.AHHA": "Data Source=YOUR_SERVER;Initial Catalog=YOUR_DATABASE;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;"
  }
